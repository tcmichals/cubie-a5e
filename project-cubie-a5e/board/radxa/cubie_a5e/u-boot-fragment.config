# CONFIG_TOOLS_MKEFICAPSULE is not set

# -------------------------------------------------------
# Device tree overlay support
# Required for: fdt addr / fdt resize / fdt apply in boot.cmd
# Without OF_LIBFDT_OVERLAY, fdt apply is a no-op / missing
# -------------------------------------------------------
CONFIG_OF_LIBFDT=y
CONFIG_OF_LIBFDT_OVERLAY=y
CONFIG_SUPPORT_OF_CONTROL=y
CONFIG_CMD_FDT=y

# -------------------------------------------------------
# MMC / FAT access
# Required for: load mmc 0:1 <addr> <file>
# -------------------------------------------------------
CONFIG_CMD_MMC=y
CONFIG_CMD_FAT=y
CONFIG_FS_FAT=y
CONFIG_FAT_WRITE=n

# -------------------------------------------------------
# Generic load command
# Required for: load mmc 0:1 ${fdt_addr_r} ...
# -------------------------------------------------------
CONFIG_CMD_LOAD=y

# -------------------------------------------------------
# AArch64 kernel boot
# Required for: booti ${kernel_addr_r} - ${fdt_addr_r}
# -------------------------------------------------------
CONFIG_CMD_BOOTI=y
