CONFIG_NET=y
CONFIG_WIRELESS=y
CONFIG_CFG80211=y
CONFIG_ARCH_SUNXI=y
CONFIG_ARM64_VA_BITS_48=y
CONFIG_NET_ETHERNET=y
CONFIG_NET_VENDOR_STMICRO=y
CONFIG_STMMAC_ETH=y
CONFIG_STMMAC_PLATFORM=y
CONFIG_REALTEK_PHY=y
CONFIG_USB_SUPPORT=y
CONFIG_USB=y
CONFIG_USB_XHCI_HCD=y
CONFIG_USB_XHCI_PLATFORM=y
CONFIG_SPI_SUNXI=y
CONFIG_SPI_SPIDEV=y
CONFIG_MEDIA_SUPPORT=y
CONFIG_VIDEO_DEV=y

# Real-time validation baseline
CONFIG_EXPERT=y
CONFIG_HIGH_RES_TIMERS=y
CONFIG_PREEMPT_RT=y
CONFIG_HZ_1000=y
CONFIG_DRM=y
CONFIG_DRM_ETNAVIV=y
CONFIG_MAILBOX=y
CONFIG_SUN6I_MSGBOX=y
CONFIG_SUNXI_MAILBOX_T527=y
# Remoteproc / RPMsg
CONFIG_REMOTEPROC=y
CONFIG_REMOTEPROC_CDEV=y
CONFIG_SUNXI_T527_RPROC=y
CONFIG_RPMSG=y
CONFIG_RPMSG_VIRTIO=y
CONFIG_RPMSG_CHAR=y
# Blueprint 5: GDB debug via remoteproc sysfs + ARM CoreSight DAP (no /dev/mem needed)
# STRICT_DEVMEM remains enabled (default) - remoteproc driver handles all register access
# iomem=relaxed is NOT used - kernel driver owns clock/reset/ITCM access
CONFIG_UNWINDER_FRAME_POINTER=y
